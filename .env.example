# AgentForge environment configuration
# Copy to backend/.env and adjust values

AGENTFORGE_HOST=127.0.0.1
AGENTFORGE_PORT=8765
AGENTFORGE_WORKSPACE_ROOT=/home/joruf/Dokumente
AGENTFORGE_OLLAMA_BASE_URL=http://your-nas-or-server:11434
AGENTFORGE_DEFAULT_MODEL=ollama/llama3.1:8b
AGENTFORGE_LLM_AUTO_ROUTING=true
AGENTFORGE_OPENAI_API_KEY=
AGENTFORGE_OPENAI_API_BASE=
AGENTFORGE_ANTHROPIC_API_KEY=
AGENTFORGE_GEMINI_API_KEY=
AGENTFORGE_GROQ_API_KEY=
AGENTFORGE_MISTRAL_API_KEY=
AGENTFORGE_DEFAULT_MEMORY_TOKENS=32000
AGENTFORGE_UI_LANGUAGE=en
AGENTFORGE_WEB_SEARCH_ENABLED=true
AGENTFORGE_WEB_SEARCH_MAX_RESULTS=5

# Web search providers (no API keys): duckduckgo, wikipedia, duckduckgo_instant
# AGENTFORGE_WEB_SEARCH_PROVIDERS=["duckduckgo","wikipedia","duckduckgo_instant"]
# Coding tasks prefer e.g. deepseek-coder, codellama
# Research/documentation use qwen, gemma, mistral

# Local CPU testing only: force one model for ALL tasks (Quick Chat, agents, titles).
# Leave unset or empty to use default_model and task-based auto routing.
# AGENTFORGE_OVERRIDE_MODEL=ollama/llama3.2:1b-instruct-q4_K_M
# LLM request timeout in seconds (increase for remote/CPU Ollama)
# AGENTFORGE_LLM_REQUEST_TIMEOUT=300
# Timeout for AI chat title generation
# AGENTFORGE_LLM_TITLE_TIMEOUT=45
# Multi-agent discussion rounds when using Ollama (default 2)
# AGENTFORGE_MULTI_AGENT_MAX_ROUNDS_OLLAMA=2
# Multi-agent discussion rounds for cloud models (default 4)
# AGENTFORGE_MULTI_AGENT_MAX_ROUNDS=4

# Context plugins (free APIs, no keys required)
# AGENTFORGE_CONTEXT_PLUGINS_ENABLED=true
# AGENTFORGE_CONTEXT_TIMEZONE=Europe/Berlin
# AGENTFORGE_CONTEXT_COUNTRY_CODE=DE
# AGENTFORGE_CONTEXT_CITY=Berlin
# AGENTFORGE_CONTEXT_EXCHANGE_BASE=EUR
# AGENTFORGE_CONTEXT_PLUGINS_ENABLED_LIST=["datetime","weather","holidays","exchange_rates","sun_times","country_facts","random_fact"]
